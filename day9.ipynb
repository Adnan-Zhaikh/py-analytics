    "import pandas as pd\n",
    "\n",
    "df1 = pd.DataFrame({\"Employee\": [\"Adnan\", \"Sabir\"], \"Role\": [\"Developer\", \"Analyst\"]})\n",
    "df2 = pd.DataFrame({\"Employee\": [\"Sabir\", \"Adnan\"], \"Projects\": [7, 14]})\n",
    "\n",
    "merged_df = pd.merge(df1, df2, on=\"Employee\")\n",
    "print(merged_df)"
